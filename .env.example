NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Database (PostgreSQL) — pooled connection for queries
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
# Direct connection — used for migrations (bypasses pgbouncer)
DIRECT_URL=postgresql://user:password@host:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-minimum-32-characters-long
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# S3 (MinIO for local, AWS S3 for production)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=inventrack
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Email (optional in development)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# CORS (comma-separated origins, defaults to localhost in dev)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
