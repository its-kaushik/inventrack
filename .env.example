# Node
NODE_ENV=development
PORT=3000

# Database (Supabase example)
# Pooled connection (port 6543) — used by the app for queries via PgBouncer
DATABASE_URL="postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — required by pg-boss for LISTEN/NOTIFY. Optional if not using PgBouncer.
DATABASE_URL_DIRECT="postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# JWT
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# S3 / Cloudflare R2
S3_BUCKET=inventrack-dev
S3_REGION=auto
S3_ACCESS_KEY=minioaccess
S3_SECRET_KEY=miniosecret
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000/inventrack-dev

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info
